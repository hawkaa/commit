{
  "env": {
    "browser": true,
    "webextensions": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-undef": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "globals": {
    "Prover": "readonly",
    "Presentation": "readonly"
  }
}
