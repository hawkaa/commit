{
  "manifest_version": 3,
  "name": "Commit — Verifiable Trust Scores",
  "version": "0.2.0",
  "description": "Trust signals you can verify. See Commit Scores for GitHub repos, businesses, and services — based on public evidence, not opinions.",
  "homepage_url": "https://commit-backend.fly.dev",
  "permissions": ["storage", "alarms", "offscreen"],
  "host_permissions": [
    "https://github.com/*",
    "https://www.google.com/*",
    "https://www.google.no/*",
    "https://notary.pse.dev/*",
    "wss://notary.pse.dev/*",
    "https://commit-verifier.fly.dev/*",
    "wss://commit-verifier.fly.dev/*",
    "https://api.github.com/*",
    "https://commit-backend.fly.dev/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content-github.js"],
      "css": ["trust-card.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.google.com/*", "https://www.google.no/*"],
      "js": ["content-google.js"],
      "css": ["trust-card.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["*.wasm", "tlsn-wasm/*.wasm", "tlsn-wasm/snippets/**/*.js"],
      "matches": ["https://github.com/*", "https://www.google.com/*", "https://www.google.no/*"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
