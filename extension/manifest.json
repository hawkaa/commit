{
  "manifest_version": 3,
  "name": "Commit — Verifiable Trust Scores",
  "version": "0.1.0",
  "description": "Trust signals you can verify. See Commit Scores for GitHub repos, businesses, and services — based on public evidence, not opinions.",
  "homepage_url": "https://commit-backend.fly.dev",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://github.com/*",
    "https://www.google.com/*",
    "https://www.google.no/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content-github.js"],
      "css": ["trust-card.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.google.com/*", "https://www.google.no/*"],
      "js": ["content-google.js"],
      "css": ["trust-card.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
